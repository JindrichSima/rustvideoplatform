{
  "db_name": "PostgreSQL",
  "query": "SELECT m.id, m.name, m.owner, m.views, m.type\n         FROM media m\n         INNER JOIN subscriptions s ON m.owner = s.target\n         WHERE s.subscriber = $1 AND m.public = true\n         ORDER BY m.upload DESC\n         LIMIT 100;",
