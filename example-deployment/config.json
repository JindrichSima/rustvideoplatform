{
    "scylla_nodes": ["scylladb:9042"],
    "scylla_keyspace": "videoplatform",
    "redis_url": "redis://dragonfly:6379",
    "instancename":"vids.cz",
    "welcome":"Welcome to our experimental open-source multimedia sharing platform! Dive into a vibrant community where creativity knows no bounds. Whether you're a photographer, musician, filmmaker, or digital artist, our site offers the perfect space to showcase your work, connect with like-minded individuals, and explore an endless stream of inspiration. Join us today and start sharing your creativity with the world!",
    "custom_upload_url": "https://upload.vids.cz/uploadform",
    "custom_session_domain": ".vids.cz",
    "meilisearch_url": "http://meilisearch:7700",
    "meilisearch_key": "SECRET_PASSWORD_HERE",
    "source_server_url": "https://source.vids.cz",

    "tls_cert": null,
    "tls_key": null,
    "enable_http2": true,
    "enable_brotli": true,
    "enable_zstd": true,
    "enable_hsts": false,

    "whisper": {
        "url": "http://whisper:8080/inference",
        "model": "whisper-1",
        "response_format": "vtt",
        "output_label": "AI_transcription",
        "max_chunk_secs": 30,
        "silence_noise_db": -30,
        "silence_min_duration": 0.5,
        "temperature": 0.5
    },

    "translation": {
        "languages": ["en", "cs"],
        "llama_url": "http://translatellama:8083",
        "source_language": "en",
        "timeout_secs": 500
    },

    "embedding": {
        "url": "http://embedllama:8084/v1/embeddings",
        "model": "YOUR_QWEN3_EMBEDDING_MODEL",
        "timeout_secs": 30
    },

    "audio": {
        "codec": "libopus",
        "lossless_bitrate": "300k",
        "lossy_bitrate": "256k",
        "vbr": "on",
        "application": "audio",
        "output_format": "ogg",
        "lossless_codecs": ["flac", "wav", "pcm_s16le"]
    },

    "picture": {
        "crf": 26,
        "thumbnail_crf": 28,
        "jpg_quality": 25,
        "thumbnail_width": 1280,
        "thumbnail_height": 720,
        "cover_crf": 26,
        "cover_thumbnail_crf": 30
    },

    "video": {
        "encoder": "qsv",
        "max_resolution_steps": 4,
        "min_dimension": 240,
        "fps_cap": 120.0,
        "audio_bitrate_base": 256,
        "threshold_2k_pixels": 3686400,
        "audio_bitrate_2k_bonus": 100,
        "quality_steps": [
            {
                "label": "original",
                "scale_divisor": 1,
                "audio_bitrate_divisor": 1
            },
            {
                "label": "half_resolution",
                "scale_divisor": 2,
                "audio_bitrate_divisor": 2
            },
            {
                "label": "quarter_resolution",
                "scale_divisor": 4,
                "audio_bitrate_divisor": 4
            },
            {
                "label": "eighth_resolution",
                "scale_divisor": 8,
                "audio_bitrate_divisor": 8
            }
        ],
        "filters": "unsharp=3:3:1.0:3:3:0.0,format=p010le",

        "nvenc": {
            "codec": "av1_nvenc",
            "preset": "p7",
            "tier": "high",
            "rc": "vbr",
            "cq": 26,
            "lookahead": 32,
            "temporal_aq": true
        },
        "qsv": {
            "codec": "av1_qsv",
            "preset": "veryslow",
            "global_quality": 27,
            "look_ahead_depth": 60
        },
        "vaapi": {
            "codec": "av1_vaapi",
            "quality": 51,
            "compression_ratio": 5
        },

        "dash": {
            "audio_codec": "libopus",
            "audio_vbr": "constrained",
            "audio_channels": 2,
            "segment_duration": 10
        },
        "thumbnail": {
            "width": 1920,
            "height": 1080
        },
        "showcase": {
            "width": 480,
            "fps": 2,
            "max_frames": 60,
            "quality": 40,
            "cpu_used": 2
        },
        "preview_sprites": {
            "interval_seconds": 5.0,
            "thumb_width": 640,
            "thumb_height": 360,
            "max_sprites_per_file": 100,
            "sprites_across": 10,
            "quality": 40,
            "parallel_limit": 4
        }
    }
}
